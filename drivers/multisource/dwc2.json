{
  "schema": 1,
  "name": "dwc2",
  "description": "Pinned Linux Synopsys DesignWare USB2 dual-role controller module",
  "kbuild": "../../linux/drivers/usb/dwc2/Makefile",
  "kbuild_target": "dwc2.ko",
  "kconfig": [
    "CONFIG_USB_DWC2=m",
    "CONFIG_USB_DWC2_DUAL_ROLE=y",
    "CONFIG_DEBUG_FS=n"
  ],
  "sources": [
    "../../linux/drivers/usb/dwc2/core.c",
    "../../linux/drivers/usb/dwc2/core_intr.c",
    "../../linux/drivers/usb/dwc2/platform.c",
    "../../linux/drivers/usb/dwc2/drd.c",
    "../../linux/drivers/usb/dwc2/params.c",
    "../../linux/drivers/usb/dwc2/hcd.c",
    "../../linux/drivers/usb/dwc2/hcd_intr.c",
    "../../linux/drivers/usb/dwc2/hcd_queue.c",
    "../../linux/drivers/usb/dwc2/hcd_ddma.c",
    "../../linux/drivers/usb/dwc2/gadget.c"
  ]
}
