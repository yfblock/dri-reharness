#!/bin/sh
mount -t proc proc /proc 2>/dev/null
mount -t sysfs sysfs /sys 2>/dev/null
mount -t devtmpfs devtmpfs /dev 2>/dev/null
echo "=== insmod device-registrar target=ftgpio010-gpio ==="
insmod /lib/modules/device-registrar.ko target="ftgpio010-gpio" 2>&1
sleep 0.3
echo "=== insmod ftgpio010_gpio ==="
insmod /lib/modules/ftgpio010_gpio.ko 2>&1
sleep 0.3
echo "=== dmesg (driver+registrar) ==="
dmesg | grep -iE 'ftgpio010-gpio|ftgpio010_gpio|ftgpio|gpiochip|probe|gpio' | tail -25
echo "=== /sys/bus/gpio/devices ==="
ls /sys/bus/gpio/devices/ 2>&1 | head
echo "=== rmmod ftgpio010_gpio ==="
rmmod ftgpio010_gpio 2>&1
rmmod device-registrar 2>/dev/null
sleep 0.2
echo "=== QEMU_PLAT_DONE ==="
echo o > /proc/sysrq-trigger 2>/dev/null
